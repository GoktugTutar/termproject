generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StudyTime {
  morning
  afternoon
  evening
  night
}

enum StudyStyle {
  deep_focus
  distributed
  normal
}

model User {
  id                 Int              @id @default(autoincrement())
  email              String           @unique
  passwordHash       String
  preferredStudyTime StudyTime        @default(morning)
  studyStyle         StudyStyle       @default(normal)
  busySlots          UserBusySlot[]
  lessons            Lesson[]
  terms              Term[]
  checklists         DailyChecklist[]
  weeklyFeedbacks    WeeklyFeedback[]
  scheduledBlocks    ScheduledBlock[]
  profile            StudentProfile?
}

model StudentProfile {
  id                 Int      @id @default(autoincrement())
  userId             Int      @unique
  user               User     @relation(fields: [userId], references: [id])
  updatedAt          DateTime @updatedAt

  // Rolling 7-day metrics
  completionRate7d   Float    @default(0)
  avgStress7d        Float    @default(3)
  avgFatigue7d       Float    @default(3)

  // Per-day-of-week completion rates (Mon=0..Sun=6), stored as JSON string
  dowCompletionRates String   @default("[0,0,0,0,0,0,0]")

  // Avg blockCount in sessions where student fully completed (sweet spot)
  sweetSpotBlocks    Float    @default(2)

  // Avg stress on days where an exam is <=7 days away
  stressNearExam     Float    @default(3)

  // % of last 14 days with at least 1 completed block
  consistencyScore   Float    @default(0)

  // Total submissions used to weight averages
  totalSubmissions   Int      @default(0)
}


model UserBusySlot {
  id           Int    @id @default(autoincrement())
  userId       Int
  user         User   @relation(fields: [userId], references: [id])
  dayOfWeek    Int
  startTime    String
  endTime      String
  fatigueLevel Int
}

model Term {
  id        Int       @id @default(autoincrement())
  userId    Int
  user      User      @relation(fields: [userId], references: [id])
  name      String?
  isActive  Boolean   @default(true)
  startedAt DateTime  @default(now())
  endedAt   DateTime?
  lessons   Lesson[]
}

model Lesson {
  id                  Int              @id @default(autoincrement())
  userId              Int
  user                User             @relation(fields: [userId], references: [id])
  termId              Int?
  term                Term?            @relation(fields: [termId], references: [id])
  name                String
  difficulty          Int
  keyfiDelayCount     Int              @default(0)
  zorunluDelayCount   Int              @default(0)
  zorunluMissedBlocks Int              @default(0)
  needsMoreTime       Int              @default(0)
  exams               LessonExam[]
  deadlines           LessonDeadline[]
  scheduledBlocks     ScheduledBlock[]
}

model LessonExam {
  id       Int      @id @default(autoincrement())
  lessonId Int
  lesson   Lesson   @relation(fields: [lessonId], references: [id])
  examDate DateTime
}

model LessonDeadline {
  id           Int      @id @default(autoincrement())
  lessonId     Int
  lesson       Lesson   @relation(fields: [lessonId], references: [id])
  deadlineDate DateTime
  title        String?
}

model ScheduledBlock {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id])
  lessonId   Int
  lesson     Lesson   @relation(fields: [lessonId], references: [id])
  date       DateTime
  startTime  String
  endTime    String
  blockCount Int
  isReview   Boolean  @default(false)
  completed  Boolean  @default(false)
  weekStart  DateTime
}

model DailyChecklist {
  id           Int             @id @default(autoincrement())
  userId       Int
  user         User            @relation(fields: [userId], references: [id])
  date         DateTime
  stressLevel  Int             @default(3)
  fatigueLevel Int             @default(3)
  items        ChecklistItem[]
}

model ChecklistItem {
  id              Int            @id @default(autoincrement())
  checklistId     Int
  checklist       DailyChecklist @relation(fields: [checklistId], references: [id])
  lessonId        Int
  plannedBlocks   Int
  completedBlocks Int            @default(0)
  delayed         Boolean        @default(false)
}

model WeeklyFeedback {
  id               Int              @id @default(autoincrement())
  userId           Int
  user             User             @relation(fields: [userId], references: [id])
  weekStart        DateTime
  weekloadFeedback String
  lessonFeedbacks  LessonFeedback[]
}

model LessonFeedback {
  id               Int            @id @default(autoincrement())
  weeklyFeedbackId Int
  weeklyFeedback   WeeklyFeedback @relation(fields: [weeklyFeedbackId], references: [id])
  lessonId         Int
  needsMoreTime    Int
}
